.page { min-height: 100vh; padding: 32rpx 28rpx 56rpx; background: #f5f6f8; box-sizing: border-box; }
.home-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0 20rpx; gap: 20rpx; }
.hello { font-size: 38rpx; font-weight: 800; color: #172033; flex: 1; min-width: 0; }
.mine-button { width: 116rpx; height: 64rpx; line-height: 64rpx; margin-left: auto; margin-right: 0; padding: 0; border-radius: 32rpx; background: #ffffff; color: #16a34a; font-size: 26rpx; flex-shrink: 0; }
.search-box { height: 84rpx; line-height: 84rpx; padding: 0 30rpx; border-radius: 42rpx; background: #ffffff; color: #94a3b8; font-size: 28rpx; box-sizing: border-box; }
.section-title { margin: 36rpx 0 20rpx; font-size: 32rpx; font-weight: 800; color: #1f2937; }
.category-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18rpx; }
.category-item { height: 92rpx; line-height: 92rpx; border-radius: 12rpx; background: #ffffff; color: #475569; text-align: center; font-size: 28rpx; font-weight: 600; }
.empty { padding: 48rpx 0; color: #94a3b8; text-align: center; font-size: 26rpx; }
.goods-list { display: flex; flex-direction: column; gap: 20rpx; }
.goods-card { display: flex; padding: 20rpx; border-radius: 14rpx; background: #ffffff; }
.goods-image, .goods-image-img { width: 132rpx; height: 132rpx; border-radius: 12rpx; flex-shrink: 0; }
.goods-image { line-height: 132rpx; background: #dbe4ea; color: #607080; text-align: center; font-size: 22rpx; }
.goods-info { margin-left: 22rpx; flex: 1; min-width: 0; }
.goods-title { font-size: 30rpx; font-weight: 700; color: #1f2937; }
.goods-meta { margin-top: 18rpx; font-size: 24rpx; color: #94a3b8; }
.goods-price { margin-top: 18rpx; color: #e11d48; font-size: 32rpx; font-weight: 800; }