<view class="page">
  <view class="profile-card">
    <view class="avatar" bindtap="chooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
      <text wx:else>头像</text>
    </view>
    <button class="wechat-button" bindtap="askUseWechatProfile">使用微信昵称和头像</button>
  </view>

  <view class="form-card">
    <view class="label">昵称</view>
    <input class="input" value="{{nickname}}" placeholder="请输入昵称" bindinput="onNicknameInput" />
    <view class="label">手机号</view>
    <input class="input" value="{{phone}}" placeholder="请输入手机号" bindinput="onPhoneInput" />
    <button class="save-button" loading="{{loading}}" bindtap="saveProfile">保存资料</button>
  </view>
</view>