<view class="page">
  <view class="title">学生认证</view>
  <view class="desc">请填写真实身份信息，提交后由管理员审核。</view>

  <view class="form-card">
    <view class="label">姓名</view>
    <input class="input" value="{{realName}}" placeholder="请输入姓名" bindinput="onRealNameInput" />

    <view class="label">学号</view>
    <input class="input" type="number" value="{{studentId}}" placeholder="请输入学号" bindinput="onStudentIdInput" />

    <view class="label">学院</view>
    <input class="input" value="{{college}}" placeholder="请输入学院" bindinput="onCollegeInput" />

    <button class="submit-button" loading="{{loading}}" bindtap="submitAuth">提交认证</button>
  </view>
</view>