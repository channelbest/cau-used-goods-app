.page { min-height: 100vh; padding: 48rpx 32rpx; background: #f5f6f8; box-sizing: border-box; }
.title { font-size: 38rpx; font-weight: 800; color: #172033; }
.desc { margin-top: 16rpx; font-size: 25rpx; color: #64748b; }
.form-card { margin-top: 36rpx; padding: 30rpx; border-radius: 16rpx; background: #ffffff; }
.label { margin: 26rpx 0 12rpx; color: #475569; font-size: 26rpx; font-weight: 600; }
.input { height: 84rpx; padding: 0 24rpx; border-radius: 12rpx; background: #f1f5f9; font-size: 28rpx; box-sizing: border-box; }
.submit-button { margin-top: 42rpx; height: 86rpx; line-height: 86rpx; border-radius: 12rpx; background: #16a34a; color: #ffffff; font-size: 30rpx; font-weight: 700; }