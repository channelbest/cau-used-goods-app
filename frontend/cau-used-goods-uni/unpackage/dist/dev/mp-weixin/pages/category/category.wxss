.page { min-height: 100vh; padding: 32rpx 28rpx; background: #f5f6f8; box-sizing: border-box; }
.title { margin: 16rpx 0 24rpx; font-size: 38rpx; font-weight: 800; color: #172033; }
.sort-row { display: flex; gap: 14rpx; margin-bottom: 24rpx; }
.sort-item { flex: 1; height: 68rpx; line-height: 68rpx; border-radius: 34rpx; background: #ffffff; color: #64748b; text-align: center; font-size: 24rpx; }
.sort-item.active { background: #16a34a; color: #ffffff; font-weight: 700; }
.empty { padding: 48rpx 0; color: #94a3b8; text-align: center; font-size: 26rpx; }
.goods-list { display: flex; flex-direction: column; gap: 18rpx; }
.goods-card { display: flex; padding: 20rpx; border-radius: 14rpx; background: #ffffff; }
.goods-image, .goods-image-img { width: 128rpx; height: 128rpx; border-radius: 12rpx; flex-shrink: 0; }
.goods-image { line-height: 128rpx; background: #dbe4ea; color: #607080; text-align: center; font-size: 22rpx; }
.goods-info { margin-left: 22rpx; flex: 1; }
.goods-title { font-size: 30rpx; font-weight: 700; color: #1f2937; }
.goods-meta { margin-top: 18rpx; color: #94a3b8; font-size: 24rpx; }
.goods-price { margin-top: 18rpx; color: #e11d48; font-size: 32rpx; font-weight: 800; }